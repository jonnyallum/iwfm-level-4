{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iwfm-level-4/schemas/learner-attempt.schema.json",
  "title": "LearnerAttempt",
  "description": "A single learner answer to an assessment item, with the mark awarded and feedback. Written answers use the marking-guide band; spoken answers additionally carry the spoken rubric score.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "learner_id", "item_id", "submitted_answer", "attempted_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable unique attempt id."
    },
    "learner_id": {
      "type": "string",
      "description": "Learner this attempt belongs to."
    },
    "item_id": {
      "type": "string",
      "description": "AssessmentItem id being answered."
    },
    "mode": {
      "type": "string",
      "enum": ["written", "spoken"],
      "default": "written",
      "description": "Whether the answer was typed or spoken (role-play / interview practice)."
    },
    "submitted_answer": {
      "type": "string",
      "description": "The learner's answer text or transcript."
    },
    "band": {
      "type": "string",
      "enum": ["Distinction", "Pass", "Borderline", "Not yet"],
      "description": "Written marking-guide band."
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "description": "Numeric score where the item carries marks."
    },
    "score_max": {
      "type": "number",
      "minimum": 0,
      "description": "Maximum marks for the item."
    },
    "spoken_rubric": {
      "type": "object",
      "additionalProperties": false,
      "description": "Spoken-answer rubric scores (0-4 each, total /24) for spoken mode.",
      "properties": {
        "decision": { "type": "integer", "minimum": 0, "maximum": 4 },
        "safety_priority": { "type": "integer", "minimum": 0, "maximum": 4 },
        "structure": { "type": "integer", "minimum": 0, "maximum": 4 },
        "composure": { "type": "integer", "minimum": 0, "maximum": 4 },
        "audience_language": { "type": "integer", "minimum": 0, "maximum": 4 },
        "brevity": { "type": "integer", "minimum": 0, "maximum": 4 },
        "total": { "type": "integer", "minimum": 0, "maximum": 24 },
        "band": {
          "type": "string",
          "enum": ["Interview-ready", "Nearly there", "Developing", "Not yet"]
        }
      }
    },
    "capped_reason": {
      "type": "string",
      "enum": [
        "traded-safety",
        "bluffed-figure",
        "relied-on-reputation",
        "no-decision",
        "accepted-risk-undocumented"
      ],
      "description": "If an automatic cap from the marking guide or spoken rubric was applied, why."
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What the answer did well."
    },
    "improvements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "The most useful fixes for next time."
    },
    "ai_feedback_id": {
      "type": "string",
      "description": "Linked AiTutorFeedback record, if generated by the tutor."
    },
    "attempted_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
